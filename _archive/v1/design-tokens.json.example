{
  "$schema": "https://json.schemastore.org/design-tokens.json",
  "name": "Claude Design Premium Starter Tokens (Example)",
  "version": "0.2.0",
  "description": "Generated from starter-kit/static/tokens.css. CSS is the canonical canvas token source; regenerate this JSON after token edits.",
  "color": {
    "base": {
      "white": "#fbfcf8",
      "black": "#080c08",
      "gray": {
        "50": "#fbfcf8",
        "100": "#f3f5ef",
        "200": "#e5e9df",
        "300": "#d0d7c9",
        "400": "#a8b39f",
        "500": "#77836f",
        "600": "#566150",
        "700": "#3c4738",
        "800": "#283126",
        "900": "#171f17",
        "950": "#080c08"
      }
    },
    "semantic": {
      "primary": {
        "50": "#fff4ef",
        "100": "#ffe1d6",
        "500": "#a63d2b",
        "600": "#883124",
        "700": "#6f281f"
      },
      "success": {
        "50": "#eef7ef",
        "500": "#3f7a52",
        "600": "#2f6441"
      },
      "warning": {
        "50": "#fff7df",
        "500": "#b9821a",
        "600": "#936512"
      },
      "destructive": {
        "50": "#fff0f2",
        "500": "#b33a4b",
        "600": "#912b3c"
      }
    },
    "surface": {
      "background": "#fbfcf8",
      "card": "#f6f8f2",
      "elevated": "#eef2ea",
      "muted": "#e8ede4"
    },
    "text": {
      "primary": "#171f17",
      "secondary": "#4d5948",
      "muted": "#6f7a69",
      "inverse": "#fbfcf8"
    }
  },
  "spacing": {
    "scale": {
      "0": "0px",
      "1": "4px",
      "2": "8px",
      "3": "12px",
      "4": "16px",
      "5": "20px",
      "6": "24px",
      "8": "32px",
      "10": "40px",
      "12": "48px",
      "16": "64px",
      "20": "80px",
      "24": "96px"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Aptos, \"Avenir Next\", \"Segoe UI\", system-ui, -apple-system, BlinkMacSystemFont, sans-serif",
      "display": "Georgia, \"Iowan Old Style\", \"Palatino Linotype\", \"Times New Roman\", serif",
      "mono": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", monospace"
    },
    "fontSize": {
      "xs": "12px",
      "sm": "14px",
      "base": "16px",
      "lg": "18px",
      "xl": "20px",
      "2xl": "24px",
      "3xl": "30px",
      "4xl": "36px"
    },
    "fontWeight": {
      "normal": "400",
      "medium": "500",
      "semibold": "600",
      "bold": "700"
    },
    "lineHeight": {
      "tight": "1.25",
      "normal": "1.5",
      "relaxed": "1.75"
    },
    "letterSpacing": {
      "tight": "0",
      "normal": "0",
      "wide": "0"
    }
  },
  "radius": {
    "none": "0px",
    "sm": "4px",
    "md": "8px",
    "lg": "12px",
    "xl": "16px",
    "full": "9999px"
  },
  "elevation": {
    "none": "none",
    "sm": "0 1px 2px 0 rgb(8 12 8 / 0.06)",
    "md": "0 8px 18px -12px rgb(8 12 8 / 0.22), 0 2px 5px -3px rgb(8 12 8 / 0.18)",
    "lg": "0 18px 32px -18px rgb(8 12 8 / 0.28), 0 6px 14px -10px rgb(8 12 8 / 0.24)",
    "xl": "0 28px 46px -24px rgb(8 12 8 / 0.34), 0 12px 22px -18px rgb(8 12 8 / 0.26)"
  },
  "motion": {
    "duration": {
      "fast": "150ms",
      "normal": "200ms",
      "slow": "300ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "inOut": "cubic-bezier(0.4, 0, 0.2, 1)"
    }
  },
  "breakpoint": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },
  "component": {
    "button": {
      "height": {
        "sm": "36px",
        "md": "44px",
        "lg": "52px"
      },
      "radius": "4px",
      "fontWeight": "700",
      "letterSpacing": "0"
    },
    "card": {
      "radius": "8px",
      "border": "1px",
      "padding": "24px"
    },
    "shell": {
      "sidebarWidth": "260px",
      "topbarHeight": "68px",
      "contentMaxWidth": "1180px"
    }
  }
}
